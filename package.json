{
  "name": "claude-desktop",
  "private": true,
  "version": "1.5.5",
  "description": "Claude Desktop - AI assistant with native capabilities",
  "author": {
    "name": "pretend1111",
    "email": "pretend1111@users.noreply.github.com"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:linux": "vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.claude.desktop",
    "productName": "Claude Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [],
    "extraResources": [
      {
        "from": "engine/src",
        "to": "engine/src",
        "filter": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.json", "**/*.md", "**/*.txt"]
      },
      {
        "from": "engine/bin",
        "to": "engine/bin"
      },
      {
        "from": "engine/preload.ts",
        "to": "engine/preload.ts"
      },
      {
        "from": "engine/bunfig.toml",
        "to": "engine/bunfig.toml"
      },
      {
        "from": "engine/package.json",
        "to": "engine/package.json"
      },
      {
        "from": "engine/tsconfig.json",
        "to": "engine/tsconfig.json"
      },
      {
        "from": "engine/stubs",
        "to": "engine/stubs"
      },
      {
        "from": "engine/node_modules",
        "to": "engine/node_modules"
      },
      {
        "from": "engine/vision-helper.ts",
        "to": "engine/vision-helper.ts"
      },
      {
        "from": "engine/.env",
        "to": "engine/.env"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "pretend1111",
      "repo": "claude-desktop-app"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/favicon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon-mac.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/favicon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/spectral": "^5.2.8",
    "@remix-run/router": "1.15.3",
    "archiver": "^7.0.1",
    "core-util-is": "^1.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "inherits": "^2.0.4",
    "isarray": "^2.0.5",
    "katex": "^0.16.28",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.12.2",
    "multer": "^2.1.1",
    "process-nextick-args": "^2.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "9.0.1",
    "react-router-dom": "6.22.3",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.7.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "string_decoder": "^1.3.0",
    "util-deprecate": "^1.0.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/katex": "^0.16.8",
    "@types/mermaid": "^9.1.0",
    "@types/node": "^22.14.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
